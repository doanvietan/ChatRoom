<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.chatapp.controller.VideoCallController">
    <children>
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <ImageView fx:id="remoteVideoView" fitHeight="450.0" fitWidth="650.0"
                           pickOnBounds="true" preserveRatio="false" />

                <AnchorPane pickOnBounds="false">
                    <children>
                        <StackPane layoutX="480.0" layoutY="20.0"
                                   AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0"
                                   style="-fx-border-color: white; -fx-border-width: 2; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 0);">
                            <children>
                                <ImageView fx:id="localVideoView" fitHeight="120.0" fitWidth="160.0"
                                           pickOnBounds="true" preserveRatio="true" />
                            </children>
                        </StackPane>
                    </children>
                </AnchorPane>

            </children>
        </StackPane>

        <Button layoutX="275.0" layoutY="400.0" mnemonicParsing="false" onAction="#endCall"
                style="-fx-background-color: #ff3b30; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 30;"
                text="Kết thúc"
                AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="250.0" AnchorPane.rightAnchor="250.0"/>

        <Label fx:id="statusLabel" layoutX="20.0" layoutY="20.0"
               style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-effect: dropshadow(one-pass-box, black, 8, 0.0, 2, 0);"
               text="Đang kết nối..." AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0"/>
    </children>
</AnchorPane>